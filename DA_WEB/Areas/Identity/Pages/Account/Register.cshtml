@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng Ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng Ký — Kizuna</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Josefin+Sans:wght@200;300;400;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary: #bd002c;
            --primary-dark: #8a001f;
            --ink: #1a1410;
            --paper: #f7f4f0;
            --warm-mid: #e8e2d9;
            --muted: #9a9089;
            --accent-gold: #c9a96e;
            --white: #ffffff;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; }
        body {
            font-family: 'Josefin Sans', sans-serif;
            background: var(--paper);
            color: var(--ink);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* HEADER */
        .top-bar {
            display: flex; align-items: center; justify-content: space-between;
            padding: 20px 48px;
            border-bottom: 1px solid var(--warm-mid);
            background: white;
        }
        .logo {
            display: flex; align-items: center; gap: 10px;
            text-decoration: none; color: var(--ink);
        }
        .logo-mark { width: 22px; height: 22px; color: var(--primary); }
        .logo-text {
            font-weight: 600; font-size: 15px;
            letter-spacing: 0.35em; text-transform: uppercase;
        }
        .back-link {
            font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase;
            color: var(--muted); text-decoration: none;
            transition: color 0.3s;
        }
        .back-link:hover { color: var(--primary); }

        /* MAIN LAYOUT */
        main {
            flex: 1;
            display: flex;
            align-items: stretch;
        }

        /* LEFT IMAGE — flipped side vs Login */
        .panel-form {
            width: 100%;
            display: flex; flex-direction: column; justify-content: center;
            padding: 56px 48px;
            background: white;
            animation: fadeUp 0.8s ease both;
        }
        @@media (min-width: 768px) { .panel-form { width: 50%; } }

        .panel-img {
            display: none;
            width: 50%;
            position: relative; overflow: hidden;
        }
        @@media (min-width: 768px) { .panel-img { display: block; } }
        .panel-img-bg {
            width: 100%; height: 100%;
            background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBqcrwOhJ2i86BSnTbHpl7BCl8VuIylxsS9tcvHGCARvGQpQndjkAhIrdesQxzWxrkPTdFcS9BZVb8naIeWbIMlpeja9QUONRZRAVIg233rAsVTU55bay4qjCgrUUC6n-L2hxkIOT4HgwgtF1Vc0lzOoo2LvGtxeOY9KwPtgQpw1XjDWz0zPuVVoucP8_EGDMK8PdjGuWz_djHt_QwRhMwr94DLqcBh_yfYx0mo41pVc-9CfENkiJ6JOTTSTN7EqAVi9_WAWCaKGyQ');
            background-size: cover; background-position: center;
            transition: transform 8s ease;
        }
        .panel-img:hover .panel-img-bg { transform: scale(1.04); }
        .panel-img-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(26,20,16,0.75) 0%, rgba(26,20,16,0.1) 60%);
        }
        .panel-img-text {
            position: absolute; bottom: 48px; left: 48px; right: 48px;
            color: white;
        }
        .panel-eyebrow {
            font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase;
            color: var(--accent-gold); margin-bottom: 12px;
            display: flex; align-items: center; gap: 10px;
        }
        .panel-eyebrow::before {
            content: ''; display: block;
            width: 24px; height: 1px; background: var(--accent-gold);
        }
        .panel-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 36px; font-weight: 300; line-height: 1.2;
        }
        .panel-title em { font-style: italic; color: var(--accent-gold); }

        /* FORM */
        .form-heading { margin-bottom: 32px; }
        .form-label-top {
            font-size: 9px; letter-spacing: 0.45em; text-transform: uppercase;
            color: var(--primary); margin-bottom: 12px;
            display: flex; align-items: center; gap: 10px;
        }
        .form-label-top::before {
            content: ''; display: block;
            width: 20px; height: 1px; background: var(--primary);
        }
        .form-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 48px; font-weight: 300; line-height: 1.05; color: var(--ink);
        }
        .form-title em { font-style: italic; color: var(--muted); }

        .form-row-2 {
            display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
        }

        .form-group { margin-bottom: 20px; }
        .form-group label {
            display: block;
            font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
            color: var(--muted); margin-bottom: 8px;
        }
        .form-group input {
            width: 100%;
            padding: 14px 16px;
            border: 1px solid var(--warm-mid);
            background: var(--paper);
            font-family: 'Josefin Sans', sans-serif;
            font-size: 13px; letter-spacing: 0.05em; color: var(--ink);
            outline: none;
            transition: border-color 0.3s, background 0.3s;
        }
        .form-group input:focus {
            border-color: var(--primary);
            background: white;
        }
        .form-group input::placeholder { color: var(--muted); }
        .field-error {
            color: var(--primary); font-size: 11px; margin-top: 6px; display: block;
        }

        .btn-submit {
            width: 100%; padding: 16px; margin-top: 8px;
            background: var(--primary); color: white;
            border: none; cursor: pointer;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 10px; font-weight: 600;
            letter-spacing: 0.3em; text-transform: uppercase;
            transition: background 0.3s, transform 0.2s;
            clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
        }
        .btn-submit:hover { background: var(--primary-dark); transform: translateY(-1px); }

        .form-footer {
            text-align: center; margin-top: 24px;
            font-size: 11px; letter-spacing: 0.05em; color: var(--muted);
        }
        .form-footer a {
            color: var(--ink); text-decoration: none;
            border-bottom: 1px solid var(--ink); padding-bottom: 1px;
            transition: color 0.3s, border-color 0.3s;
        }
        .form-footer a:hover { color: var(--primary); border-color: var(--primary); }

        .validation-summary {
            background: #fff0f3; border-left: 3px solid var(--primary);
            padding: 12px 16px; margin-bottom: 20px;
            font-size: 12px; color: var(--primary);
        }
        .validation-summary ul { padding-left: 16px; }

        /* FOOTER */
        footer {
            background: var(--ink);
            padding: 20px 48px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .footer-copy {
            font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
            color: rgba(255,255,255,0.3);
        }
        .footer-links { display: flex; gap: 24px; }
        .footer-links a {
            font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
            color: rgba(255,255,255,0.3); text-decoration: none;
            transition: color 0.3s;
        }
        .footer-links a:hover { color: white; }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <!-- TOP BAR -->
    <div class="top-bar">
        <a href="/" class="logo">
            <svg class="logo-mark" viewBox="0 0 48 48" fill="none">
                <path d="M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z" fill="currentColor"/>
            </svg>
            <span class="logo-text">Kizuna</span>
        </a>
        <a href="/" class="back-link">← Quay về trang chủ</a>
    </div>

    <main>
        <!-- LEFT FORM PANEL -->
        <div class="panel-form">
            <div class="form-heading">
                <div class="form-label-top">Tạo tài khoản</div>
                <h1 class="form-title">Đăng<br /><em>Ký</em></h1>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <!-- FullName -->
                <div class="form-group">
                    <label asp-for="Input.FullName">Họ và tên</label>
                    <input asp-for="Input.FullName"
                           placeholder="Nguyễn Văn A"
                           autocomplete="name" />
                    <span asp-validation-for="Input.FullName" class="field-error"></span>
                </div>

                <!-- Email + Address 2 cột -->
                <div class="form-row-2">
                    <div class="form-group">
                        <label asp-for="Input.Email">Email</label>
                        <input asp-for="Input.Email"
                               type="email"
                               placeholder="email@example.com"
                               autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label>Địa chỉ <span style="color:var(--muted);font-size:8px">(tuỳ chọn)</span></label>
                        <input name="Input.Address"
                               placeholder="Quận 1, TP.HCM" />
                    </div>
                </div>

                <!-- Password + Confirm 2 cột -->
                <div class="form-row-2">
                    <div class="form-group">
                        <label asp-for="Input.Password">Mật khẩu</label>
                        <input asp-for="Input.Password"
                               type="password"
                               placeholder="••••••••"
                               autocomplete="new-password" />
                        <span asp-validation-for="Input.Password" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.ConfirmPassword">Xác nhận mật khẩu</label>
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               placeholder="••••••••"
                               autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-submit">Tạo Tài Khoản</button>
            </form>

            <div class="form-footer">
                Đã có tài khoản?
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Đăng nhập</a>
            </div>
        </div>

        <!-- RIGHT IMAGE PANEL -->
        <div class="panel-img">
            <div class="panel-img-bg"></div>
            <div class="panel-img-overlay"></div>
            <div class="panel-img-text">
                <div class="panel-eyebrow">Kizuna Community</div>
                <h2 class="panel-title">
                    Trở Thành Một Phần<br />
                    Của <em>Câu Chuyện</em>
                </h2>
            </div>
        </div>
    </main>

    <footer>
        <span class="footer-copy">© 2025 Kizuna Clothing</span>
        <div class="footer-links">
            <a href="#">Điều khoản</a>
            <a href="#">Bảo mật</a>
        </div>
    </footer>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
