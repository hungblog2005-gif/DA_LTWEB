@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Gửi Lại Email Xác Nhận";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gửi Lại Email — Kizuna</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Josefin+Sans:wght@200;300;400;600&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary: #bd002c;
            --primary-dark: #8a001f;
            --ink: #1a1410;
            --paper: #f7f4f0;
            --warm-mid: #e8e2d9;
            --muted: #9a9089;
            --accent-gold: #c9a96e;
            --white: #ffffff;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; }
        body {
            font-family: 'Josefin Sans', sans-serif;
            background: var(--paper);
            color: var(--ink);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* TOP BAR */
        .top-bar {
            display: flex; align-items: center; justify-content: space-between;
            padding: 20px 48px;
            border-bottom: 1px solid var(--warm-mid);
            background: white;
        }
        .logo {
            display: flex; align-items: center; gap: 10px;
            text-decoration: none; color: var(--ink);
        }
        .logo-mark { width: 22px; height: 22px; color: var(--primary); }
        .logo-text {
            font-weight: 600; font-size: 15px;
            letter-spacing: 0.35em; text-transform: uppercase;
        }
        .back-link {
            font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase;
            color: var(--muted); text-decoration: none; transition: color 0.3s;
        }
        .back-link:hover { color: var(--primary); }

        /* MAIN */
        main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 20px;
        }

        .card {
            background: white;
            width: 100%;
            max-width: 480px;
            padding: 56px 48px;
            box-shadow: 0 2px 40px rgba(0,0,0,0.06);
            animation: fadeUp 0.7s ease both;
        }

        /* Icon vòng tròn */
        .icon-wrap {
            width: 64px; height: 64px;
            border: 1px solid var(--warm-mid);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 32px;
        }
        .icon-wrap svg {
            width: 28px; height: 28px;
            stroke: var(--primary); fill: none;
            stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round;
        }

        .form-label-top {
            font-size: 9px; letter-spacing: 0.45em; text-transform: uppercase;
            color: var(--primary); margin-bottom: 12px;
            display: flex; align-items: center; gap: 10px;
        }
        .form-label-top::before {
            content: ''; display: block;
            width: 20px; height: 1px; background: var(--primary);
        }

        .form-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 40px; font-weight: 300; line-height: 1.1;
            color: var(--ink); margin-bottom: 12px;
        }
        .form-title em { font-style: italic; color: var(--muted); }

        .form-desc {
            font-size: 12px; font-weight: 300;
            letter-spacing: 0.04em; line-height: 1.9;
            color: var(--muted); margin-bottom: 36px;
        }

        .form-group { margin-bottom: 28px; }
        .form-group label {
            display: block;
            font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
            color: var(--muted); margin-bottom: 8px;
        }
        .form-group input {
            width: 100%;
            padding: 14px 16px;
            border: 1px solid var(--warm-mid);
            background: var(--paper);
            font-family: 'Josefin Sans', sans-serif;
            font-size: 13px; letter-spacing: 0.05em; color: var(--ink);
            outline: none;
            transition: border-color 0.3s, background 0.3s;
        }
        .form-group input:focus {
            border-color: var(--primary);
            background: white;
        }
        .form-group input::placeholder { color: var(--muted); }
        .field-error {
            color: var(--primary); font-size: 11px;
            margin-top: 6px; display: block;
        }

        .btn-submit {
            width: 100%; padding: 16px;
            background: var(--primary); color: white;
            border: none; cursor: pointer;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 10px; font-weight: 600;
            letter-spacing: 0.3em; text-transform: uppercase;
            transition: background 0.3s, transform 0.2s;
            clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
        }
        .btn-submit:hover { background: var(--primary-dark); transform: translateY(-1px); }

        .divider {
            height: 1px; background: var(--warm-mid);
            margin: 28px 0;
        }

        .form-footer {
            text-align: center;
            font-size: 11px; letter-spacing: 0.05em; color: var(--muted);
        }
        .form-footer a {
            color: var(--ink); text-decoration: none;
            border-bottom: 1px solid var(--ink); padding-bottom: 1px;
            transition: color 0.3s, border-color 0.3s;
        }
        .form-footer a:hover { color: var(--primary); border-color: var(--primary); }

        /* Success message nếu đã gửi */
        .alert-success {
            background: #f0faf4;
            border-left: 3px solid #2d7a4f;
            padding: 14px 16px;
            margin-bottom: 24px;
            font-size: 12px;
            color: #2d7a4f;
            letter-spacing: 0.04em;
            line-height: 1.7;
        }

        .validation-summary {
            background: #fff0f3; border-left: 3px solid var(--primary);
            padding: 12px 16px; margin-bottom: 24px;
            font-size: 12px; color: var(--primary);
        }
        .validation-summary ul { padding-left: 16px; }

        /* FOOTER */
        footer {
            background: var(--ink);
            padding: 20px 48px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .footer-copy {
            font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
            color: rgba(255,255,255,0.3);
        }
        .footer-links { display: flex; gap: 24px; }
        .footer-links a {
            font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
            color: rgba(255,255,255,0.3); text-decoration: none; transition: color 0.3s;
        }
        .footer-links a:hover { color: white; }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <!-- TOP BAR -->
    <div class="top-bar">
        <a href="/" class="logo">
            <svg class="logo-mark" viewBox="0 0 48 48" fill="none">
                <path d="M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z" fill="currentColor"/>
            </svg>
            <span class="logo-text">Kizuna</span>
        </a>
        <a asp-page="./Login" class="back-link">← Quay lại đăng nhập</a>
    </div>

    <main>
        <div class="card">

            <!-- Icon email -->
            <div class="icon-wrap">
                <svg viewBox="0 0 24 24">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
            </div>

            <div class="form-label-top">Xác nhận tài khoản</div>
            <h1 class="form-title">Gửi Lại<br /><em>Email</em></h1>
            <p class="form-desc">
                Nhập địa chỉ email đã đăng ký. Chúng tôi sẽ gửi lại link xác nhận tài khoản cho bạn.
            </p>

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <form method="post">
                <div class="form-group">
                    <label asp-for="Email">Địa chỉ Email</label>
                    <input asp-for="Email"
                           type="email"
                           placeholder="email@example.com"
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <button type="submit" class="btn-submit">Gửi Email Xác Nhận</button>
            </form>

            <div class="divider"></div>

            <div class="form-footer" style="margin-bottom:10px">
                Đã xác nhận tài khoản?
                <a asp-page="./Login">Đăng nhập</a>
            </div>
            <div class="form-footer">
                Chưa có tài khoản?
                <a asp-page="./Register">Đăng ký ngay</a>
            </div>
        </div>
    </main>

    <footer>
        <span class="footer-copy">© 2025 Kizuna Clothing</span>
        <div class="footer-links">
            <a href="#">Điều khoản</a>
            <a href="#">Bảo mật</a>
        </div>
    </footer>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
