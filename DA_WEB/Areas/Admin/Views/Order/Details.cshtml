@model DA_WEB.Models.Order
@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-heading">
    <a asp-action="Index" style="font-size: 12px; color: var(--muted); text-decoration: none; display: flex; align-items: center; gap: 4px; margin-bottom: 12px;">
        <span class="material-symbols-outlined" style="font-size: 16px;">arrow_back</span> Back to Orders
    </a>
    <h1 class="page-title">Order <em>#@Model.Id</em></h1>
    <p class="page-subtitle">Placed on @Model.OrderDate.ToString("f")</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="background: #d4edda; color: #155724; padding: 12px 24px; border-radius: 4px; margin-bottom: 24px; font-size: 13px;">
        @TempData["Success"]
    </div>
}

<div class="form-grid">
    <div class="form-col-main">
        <div class="form-card">
            <div class="form-card-header">Items Ordered</div>
            <div class="form-card-body" style="padding: 0;">
                <table style="width: 100%; text-align: left; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--warm-mid); font-size: 11px; text-transform: uppercase; color: var(--muted); letter-spacing: 0.1em;">
                            <th style="padding: 16px 24px;">Product</th>
                            <th style="padding: 16px 24px;">Size</th>
                            <th style="padding: 16px 24px; text-align: center;">Qty</th>
                            <th style="padding: 16px 24px; text-align: right;">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr style="border-bottom: 1px solid var(--paper); font-size: 14px;">
                                <td style="padding: 16px 24px;">
                                    <div style="font-weight: 600; color: var(--ink);">@(item.Product?.Name ?? "Unknown Product")</div>
                                </td>
                                <td style="padding: 16px 24px; color: var(--muted);">@(string.IsNullOrEmpty(item.Size) ? "Free Size" : item.Size)</td>
                                <td style="padding: 16px 24px; text-align: center;">@item.Quantity</td>
                                <td style="padding: 16px 24px; text-align: right; font-weight: 600;">@((item.Quantity * item.UnitPrice).ToString("N0"))₫</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div style="padding: 16px 24px; text-align: right; font-size: 18px; color: var(--ink); border-top: 1px solid var(--warm-mid);">
                    Total Amount: <strong>@Model.TotalAmount.ToString("N0")₫</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="form-col-side">
        <div class="form-card" style="margin-bottom: 24px;">
            <div class="form-card-header">Customer Info</div>
            <div class="form-card-body">
                <div style="margin-bottom: 12px;">
                    <p style="font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">Name</p>
                    <p style="font-size: 14px; color: var(--ink); font-weight: 600;">@Model.FullName</p>
                </div>
                <div style="margin-bottom: 12px;">
                    <p style="font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">Contact</p>
                    <p style="font-size: 14px; color: var(--ink);">@Model.Email<br />@Model.Phone</p>
                </div>
                <div>
                    <p style="font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">Shipping Address</p>
                    <p style="font-size: 14px; color: var(--ink); line-height: 1.5;">@Model.Address</p>
                </div>
            </div>
        </div>

        <div class="form-card">
            <div class="form-card-header">Update Status</div>
            <div class="form-card-body">
                <form asp-action="UpdateStatus" method="post" style="display: flex; flex-direction: column; gap: 12px;">
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    <select name="status" class="field-input field-select" style="width: 100%;">
                        <option value="Pending" selected="@(Model.Status == "Pending")">Pending</option>
                        <option value="Processing" selected="@(Model.Status == "Processing")">Processing</option>
                        <option value="Shipped" selected="@(Model.Status == "Shipped")">Shipped</option>
                        <option value="Delivered" selected="@(Model.Status == "Delivered")">Delivered</option>
                        <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>
                    </select>

                    <button type="submit" class="btn-primary-admin" style="justify-content: center; width: 100%;">
                        Update Order
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>