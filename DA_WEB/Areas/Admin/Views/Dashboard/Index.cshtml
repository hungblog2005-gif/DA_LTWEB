@model DA_WEB.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="page-heading">
    <div class="page-eyebrow">Overview</div>
    <h1 class="page-title">Admin <em>Dashboard</em></h1>
</div>

<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 32px;">
    
    <div class="form-card" style="padding: 24px;">
        <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px;">Total Revenue</p>
        <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 300; color: var(--ink);">
            @Model.TotalRevenue.ToString("N0")₫
        </h3>
    </div>

    <div class="form-card" style="padding: 24px;">
        <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px;">Total Orders</p>
        <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 300; color: var(--ink);">
            @Model.TotalOrders
        </h3>
    </div>

    <div class="form-card" style="padding: 24px;">
        <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px;">Products</p>
        <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 300; color: var(--ink);">
            @Model.TotalProducts
        </h3>
    </div>

    <div class="form-card" style="padding: 24px;">
        <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px;">Customers</p>
        <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 300; color: var(--ink);">
            @Model.TotalCustomers
        </h3>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
    
    <div>
        <div class="form-card" style="margin-bottom: 24px; padding: 24px;">
            <p style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink); margin-bottom: 16px;">
                Top Selling Products
            </p>
    
            @if (Model.TopProducts != null && Model.TopProducts.Any())
            {
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    @foreach (var item in Model.TopProducts)
                    {
                        <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 1px dashed var(--paper);">
                            <div>
                                <h4 style="font-size: 14px; font-weight: 600; color: var(--ink); margin: 0 0 4px 0;">@item.ProductName</h4>
                                <span style="font-size: 12px; color: var(--muted);">Đã bán: <strong>@item.TotalSold</strong> chiếc</span>
                            </div>
                            <div style="font-size: 14px; font-weight: bold; color: var(--primary);">
                                @item.Revenue.ToString("N0")₫
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 24px 0; color: var(--muted); font-size: 13px;">
                    Chưa có dữ liệu bán hàng.
                </div>
            }
        </div>

        <div class="form-card" style="padding: 24px;">
            <p style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink); margin-bottom: 16px;">
                Recent Orders
            </p>
            <table style="width: 100%; text-align: left; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--warm-mid); font-size: 10px; text-transform: uppercase; color: var(--muted); letter-spacing: 0.1em;">
                        <th style="padding: 12px 0;">Order ID</th>
                        <th style="padding: 12px 0;">Customer</th>
                        <th style="padding: 12px 0;">Date</th>
                        <th style="padding: 12px 0;">Status</th>
                        <th style="padding: 12px 0; text-align: right;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.RecentOrders)
                    {
                        <tr style="border-bottom: 1px solid var(--paper); font-size: 13px; color: var(--ink);">
                            <td style="padding: 12px 0;">
                                <a href="/Admin/Order/Details/@order.Id" style="color: var(--primary); font-weight: bold; text-decoration: none;">#@order.Id</a>
                            </td>
                            <td style="padding: 12px 0;">@order.FullName</td>
                            <td style="padding: 12px 0;">@order.OrderDate.ToString("dd/MM/yyyy")</td>
                            <td style="padding: 12px 0;">
                                @if (order.Status == "Pending")
                                {
                                    <span style="background: #fff3cd; color: #856404; padding: 4px 8px; border-radius: 4px; font-size: 10px;">@order.Status</span>
                                }
                                else
                                {
                                    <span style="background: #d4edda; color: #155724; padding: 4px 8px; border-radius: 4px; font-size: 10px;">@order.Status</span>
                                }
                            </td>
                            <td style="padding: 12px 0; text-align: right;">@order.TotalAmount.ToString("N0")₫</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div>
        <div class="form-card" style="margin-bottom: 24px; padding: 24px; border-left: 3px solid #d9534f;">
            <p style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #d9534f; margin-bottom: 16px;">
                <span class="material-symbols-outlined" style="font-size: 14px; vertical-align: text-bottom;">warning</span> Low Stock Alert
            </p>
            @foreach (var item in Model.LowStockProducts)
            {
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--paper);">
                    <div style="font-size: 12px; color: var(--ink);">@item.Name</div>
                    <div style="font-size: 12px; font-weight: bold; color: #d9534f;">@item.Stock left</div>
                </div>
            }
            @if (!Model.LowStockProducts.Any())
            {
                <div style="font-size: 11px; color: var(--muted);">All products are well stocked.</div>
            }
        </div>

        <div class="form-card" style="padding: 24px; border-left: 3px solid #f0ad4e;">
            <p style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #f0ad4e; margin-bottom: 16px;">
                <span class="material-symbols-outlined" style="font-size: 14px; vertical-align: text-bottom;">pending_actions</span> Action Required
            </p>
            @foreach (var item in Model.PendingOrders)
            {
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--paper);">
                    <div style="font-size: 12px; color: var(--ink);">Order #@item.Id</div>
                    <div style="font-size: 12px; color: var(--muted);">@item.OrderDate.ToString("dd/MM")</div>
                </div>
            }
            @if (!Model.PendingOrders.Any())
            {
                <div style="font-size: 11px; color: var(--muted);">No pending orders.</div>
            }
        </div>
    </div>
</div>
