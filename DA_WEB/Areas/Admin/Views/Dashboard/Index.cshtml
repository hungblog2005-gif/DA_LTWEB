@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- PAGE HEADING -->
<div class="page-heading">
    <div class="page-eyebrow">Admin Panel</div>
    <h1 class="page-title">System <em>Overview</em></h1>
    <p class="page-subtitle">Welcome back. Here's what's happening with Kizuna today.</p>
</div>

<!-- STAT CARDS -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-label">Total Revenue</span>
            <span class="material-symbols-outlined stat-icon">payments</span>
        </div>
        <div class="stat-value">245,000,000₫</div>
        <div class="stat-trend trend-up">
            <span class="material-symbols-outlined">trending_up</span>
            12.5% vs last month
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-label">New Orders</span>
            <span class="material-symbols-outlined stat-icon">shopping_bag</span>
        </div>
        <div class="stat-value">128</div>
        <div class="stat-trend trend-down">
            <span class="material-symbols-outlined">trending_down</span>
            2.4% vs last month
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <span class="stat-label">New Customers</span>
            <span class="material-symbols-outlined stat-icon">person_add</span>
        </div>
        <div class="stat-value">1,420</div>
        <div class="stat-trend trend-up">
            <span class="material-symbols-outlined">trending_up</span>
            5.8% vs last month
        </div>
    </div>
</div>

<!-- CONTENT GRID -->
<div class="content-grid">

    <!-- RECENT ORDERS -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Recent Orders</span>
            <a href="#" class="card-link">View all</a>
        </div>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="td-bold">#KZ-9921</td>
                    <td>Pham Minh Anh</td>
                    <td class="td-muted">14:20, 24/05/2025</td>
                    <td class="td-bold">1,250,000₫</td>
                    <td><span class="badge badge-pending">Pending</span></td>
                </tr>
                <tr>
                    <td class="td-bold">#KZ-9919</td>
                    <td>Le Quoc Khanh</td>
                    <td class="td-muted">12:15, 24/05/2025</td>
                    <td class="td-bold">3,400,000₫</td>
                    <td><span class="badge badge-shipping">Shipping</span></td>
                </tr>
                <tr>
                    <td class="td-bold">#KZ-9918</td>
                    <td>Tran Thu Thao</td>
                    <td class="td-muted">10:05, 24/05/2025</td>
                    <td class="td-bold">890,000₫</td>
                    <td><span class="badge badge-delivered">Delivered</span></td>
                </tr>
                <tr>
                    <td class="td-bold">#KZ-9915</td>
                    <td>Nguyen Van Nam</td>
                    <td class="td-muted">09:40, 24/05/2025</td>
                    <td class="td-bold">2,100,000₫</td>
                    <td><span class="badge badge-delivered">Delivered</span></td>
                </tr>
                <tr>
                    <td class="td-bold">#KZ-9912</td>
                    <td>Hoang Bao Chau</td>
                    <td class="td-muted">08:30, 24/05/2025</td>
                    <td class="td-bold">1,750,000₫</td>
                    <td><span class="badge badge-shipping">Shipping</span></td>
                </tr>
            </tbody>
        </table>
    </div>

