<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Josefin+Sans:wght@200;300;400;600&display=swap" rel="stylesheet" />

    <!-- Kizuna CSS -->
    <link rel="stylesheet" href="~/css/kizuna-home.css" asp-append-version="true" />

    <!-- Section dành cho CSS riêng của từng trang (nếu cần) -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @RenderBody()

    <!-- Kizuna JS -->
    <script src="~/js/kizuna-home.js" asp-append-version="true"></script>

    <!-- Section dành cho JS riêng của từng trang (nếu cần) -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>