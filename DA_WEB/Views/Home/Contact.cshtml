@{
    ViewData["Title"] = "Liên Hệ - KIZUNA";
    Layout = "_LayoutTailwind"; // Sử dụng layout đã được cập nhật
}

<!-- Navigation -->
<header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-100 px-6 lg:px-20 py-4 sticky top-0 bg-white/80 dark:bg-background-dark/80 backdrop-blur-md z-50">
    <div class="flex items-center gap-3">
        <div class="text-primary">
            <svg class="size-6" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z" fill="currentColor"></path>
            </svg>
        </div>
        <h2 class="text-slate-900 dark:text-white text-xl font-bold tracking-widest">KIZUNA</h2>
    </div>
    <nav class="hidden md:flex items-center gap-10">
        <a class="text-slate-900 dark:text-slate-300 text-sm font-medium uppercase tracking-wider hover:text-primary transition-colors" href="@Url.Action("Index", "Home")">Sản phẩm</a> <!-- Giả sử -->
        <a class="text-slate-900 dark:text-slate-300 text-sm font-medium uppercase tracking-wider hover:text-primary transition-colors" href="#">Bộ sưu tập</a>
        <a class="text-slate-900 dark:text-slate-300 text-sm font-medium uppercase tracking-wider hover:text-primary transition-colors" href="#">Câu chuyện</a>
        <a class="text-primary text-sm font-bold uppercase tracking-wider" href="@Url.Action("Contact", "Home")">Liên hệ</a> <!-- Link đến chính nó -->
    </nav>
    <div class="flex gap-4">
        <button class="p-2 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-full transition-colors">
            <span class="material-symbols-outlined text-slate-900 dark:text-white">person</span>
        </button>
        <button class="p-2 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-full transition-colors">
            <span class="material-symbols-outlined text-slate-900 dark:text-white">shopping_bag</span>
        </button>
    </div>
</header>

<main class="flex-1">
    <!-- Hero Section -->
    <section class="relative h-[450px] w-full flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 bg-slate-900/20 z-10"></div>
        <img alt="Japanese minimal garden" class="absolute inset-0 w-full h-full object-cover" data-alt="Soft focused Japanese zen garden with stone path" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBdA02990xk0ComYpJcfzq5NPsWsF9ZCP4noiOgJmTK_uKI2Kiqvd6ERnIgZv58HoQCny1FUGpGxlrGuH1G2ZbjXI6KRrQgOvqgy_uOIH5kOsUxeJitAIuaSLAm4cmQ1rnMLYRy2aPrCf_4tMu4XcOvxvuzTGKHZ4bflFkDOpuu7GZPuTmkjbC2b1umYgQrvoYFtd5dZ5GWPqv-e8uHwcRYgwu6I5I5sMPiHPPjO_RjbBqpUtOLFi3IJ3qd0to3mg" />
        <div class="relative z-20 text-center px-4">
            <h1 class="text-white text-4xl md:text-6xl font-light tracking-[0.2em] mb-4">LIÊN HỆ</h1>
            <div class="h-1 w-20 bg-primary mx-auto mb-6"></div>
            <p class="text-white text-base md:text-lg max-w-2xl mx-auto font-light leading-relaxed">
                Sự kết nối tinh tế bắt đầu từ những lời chia sẻ chân thành. Hãy để KIZUNA lắng nghe bạn.
            </p>
        </div>
    </section>

    <!-- Contact Content -->
    <div class="max-w-7xl mx-auto px-6 py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
            <!-- Form Section -->
            <section class="space-y-12">
                <div class="space-y-4">
                    <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">Gửi lời nhắn</h2>
                    <p class="text-slate-500 dark:text-slate-400 font-light">Chúng tôi sẽ phản hồi yêu cầu của bạn trong vòng 24 giờ làm việc.</p>
                </div>
                <!-- Form liên hệ - Có thể thay thế bằng form Razor sau này -->
                <form class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Họ và tên</label>
                            <input class="w-full border-0 border-b border-slate-200 dark:border-slate-700 focus:ring-0 focus:border-primary py-3 px-0 text-slate-900 dark:text-white placeholder:text-slate-300 dark:placeholder:text-slate-600 transition-all bg-transparent" placeholder="Nguyễn Văn A" type="text" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Email</label>
                            <input class="w-full border-0 border-b border-slate-200 dark:border-slate-700 focus:ring-0 focus:border-primary py-3 px-0 text-slate-900 dark:text-white placeholder:text-slate-300 dark:placeholder:text-slate-600 transition-all bg-transparent" placeholder="email@kizuna.vn" type="email" />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Chủ đề</label>
                        <input class="w-full border-0 border-b border-slate-200 dark:border-slate-700 focus:ring-0 focus:border-primary py-3 px-0 text-slate-900 dark:text-white placeholder:text-slate-300 dark:placeholder:text-slate-600 transition-all bg-transparent" placeholder="Tôi cần tư vấn về size..." type="text" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Lời nhắn</label>
                        <textarea class="w-full border-0 border-b border-slate-200 dark:border-slate-700 focus:ring-0 focus:border-primary py-3 px-0 text-slate-900 dark:text-white placeholder:text-slate-300 dark:placeholder:text-slate-600 resize-none transition-all bg-transparent" placeholder="Nội dung chi tiết..." rows="4"></textarea>
                    </div>
                    <button class="mt-8 bg-primary text-white px-12 py-4 text-sm font-bold tracking-[0.2em] uppercase hover:bg-slate-900 transition-all rounded-sm flex items-center gap-2 group">
                        Gửi yêu cầu
                        <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">send</span>
                    </button>
                </form>
            </section>

            <!-- Info Section -->
            <section class="space-y-16">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-10">
                    <!-- Location -->
                    <div class="flex gap-6 items-start">
                        <div class="bg-primary/5 dark:bg-slate-800/50 p-4 rounded-full">
                            <span class="material-symbols-outlined text-primary">location_on</span>
                        </div>
                        <div class="space-y-2">
                            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Địa chỉ cửa hàng</h3>
                            <p class="text-slate-900 dark:text-white leading-relaxed font-medium">123 Lê Lợi, Phường Bến Thành,<br />Quận 1, TP. Hồ Chí Minh</p>
                        </div>
                    </div>
                    <!-- Phone -->
                    <div class="flex gap-6 items-start">
                        <div class="bg-primary/5 dark:bg-slate-800/50 p-4 rounded-full">
                            <span class="material-symbols-outlined text-primary">call</span>
                        </div>
                        <div class="space-y-2">
                            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Số điện thoại</h3>
                            <p class="text-slate-900 dark:text-white font-medium text-lg">1900 8888</p>
                            <p class="text-slate-400 dark:text-slate-500 text-sm">Thứ 2 - Chủ Nhật: 09:00 - 21:00</p>
                        </div>
                    </div>
                    <!-- Email -->
                    <div class="flex gap-6 items-start">
                        <div class="bg-primary/5 dark:bg-slate-800/50 p-4 rounded-full">
                            <span class="material-symbols-outlined text-primary">mail</span>
                        </div>
                        <div class="space-y-2">
                            <h3 class=" uppercase tracking-widest text-slate-400 dark:text-slate-500">Email hỗ trợ</h3>
                            <p class="text-slate-900 dark:text-white font-medium underline underline-offset-4 decoration-primary/30">support@kizuna.vn</p>
                        </div>
                    </div>
                </div>
                <!-- Map Placeholder -->
                <div class="relative w-full aspect-video bg-slate-100 dark:bg-slate-800 rounded overflow-hidden grayscale contrast-125 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <div class="absolute inset-0 flex items-center justify-center flex-col gap-4 text-slate-400 dark:text-slate-500">
                        <span class="material-symbols-outlined text-4xl">map</span>
                        <p class="text-sm font-medium tracking-widest uppercase">Bản đồ cửa hàng</p>
                    </div>
                    <img alt="Map location" class="w-full h-full object-cover opacity-50" data-alt="Monochrome minimal map showing location of the shop" data-location="District 1, Ho Chi Minh City" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAwvNaxlo6dgEmyWyXLPLSatWR00umF1tpyc8msxOiHzGHukN41yrWbN5HDbUnE76tgnwU5GTaQ5_jKhTbhYUSyruE7_2xmUusVEl1VsIhsf-FAEaVlwNDUtlu345kA2M6QSE_b-rxCjsOC8B6E56NSwLsXo-vzrgr4ZiStG8srLWlW3-hATfw5OVt-o0jBkUuoHZSSQfXSTxb7eDXIhyUqq8uSDF3_d01wLQYwWw9DsPoivWd8ptSlY0eHFemCjKZde3xks9ojoZ4" />
                    <div class="absolute bottom-4 left-4 right-4 bg-white/90 dark:bg-background-dark/90 backdrop-blur p-4 border border-slate-200 dark:border-slate-700">
                        <p class="text-xs font-bold text-slate-900 dark:text-white">KIZUNA FLAGSHIP STORE</p>
                        <p class="text-[10px] text-slate-500 dark:text-slate-400 uppercase tracking-tighter">District 1, HCM City</p>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <!-- Footer Section -->
    <footer class="bg-slate-50 dark:bg-slate-900/30 border-t border-slate-100 dark:border-slate-800 pt-20 pb-10">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 text-center md:text-left">
            <div class="space-y-6">
                <div class="flex items-center justify-center md:justify-start gap-2">
                    <div class="text-primary size-5">
                        <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <path d="M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z" fill="currentColor"></path>
                        </svg>
                    </div>
                    <h3 class="font-bold tracking-widest text-slate-900 dark:text-white">KIZUNA</h3>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-light leading-relaxed">
                    Trang phục tối giản cảm hứng từ triết lý Nhật Bản. Sự tinh tế trong từng sợi vải.
                </p>
            </div>
            <div>
                <h4 class="text-xs font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-6">Liên kết</h4>
                <ul class="space-y-4 text-sm text-slate-500 dark:text-slate-400 font-light">
                    <li><a class="hover:text-primary" href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                    <li><a class="hover:text-primary" href=" @Url.Action("About", "Home")">Về chúng tôi</a></li>
                    <li><a class="hover:text-primary" href="@Url.Action("PrivacyPolicy", "Home")">Chính sách bảo mật</a></li>
                    <li><a class="hover:text-primary" href="#">Tuyển dụng</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-xs font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-6">Trợ giúp</h4>
                <ul class="space-y-4 text-sm text-slate-500 dark:text-slate-400 font-light">
                    <li><a class="hover:text-primary" href="@Url.Action("SizeGuide", "Home")">Hướng dẫn chọn size</a></li>
                    <li><a class="hover:text-primary" href="@Url.Action("ReturnPolicy", "Home")">Chính sách đổi trả</a></li>
                    <li><a class="hover:text-primary" href="#">Theo dõi đơn hàng</a></li>
                    <li><a class="hover:text-primary" href="#">Câu hỏi thường gặp</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-xs font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-6">Mạng xã hội</h4>
                <div class="flex justify-center md:justify-start gap-4">
                    <a class="p-2 bg-white dark:bg-slate-800 rounded-full hover:bg-primary hover:text-white transition-all shadow-sm" href="#">
                        <span class="material-symbols-outlined text-sm">public</span>
                    </a>
                    <a class="p-2 bg-white dark:bg-slate-800 rounded-full hover:bg-primary hover:text-white transition-all shadow-sm" href="#">
                        <span class="material-symbols-outlined text-sm">photo_camera</span>
                    </a>
                    <a class="p-2 bg-white dark:bg-slate-800 rounded-full hover:bg-primary hover:text-white transition-all shadow-sm" href="#">
                        <span class="material-symbols-outlined text-sm">play_arrow</span>
                    </a>
                </div>
            </div>
        </div>
        <div class="mt-20 border-t border-slate-200 dark:border-slate-800 pt-8 text-center text-xs text-slate-400 dark:text-slate-500 tracking-widest uppercase">
            © 2024 KIZUNA MINIMALIST WEAR. TOÀN BỘ BẢN QUYỀN ĐƯỢC BẢO LƯU.
        </div>
    </footer>
</main>