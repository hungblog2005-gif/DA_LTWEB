@{
    ViewData["Title"] = "Kizuna — Thời Trang Tối Giản Nhật Bản";
    Layout = "~/Views/Shared/_LayoutKizuna.cshtml";
}

<!-- Custom cursor -->
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- ======= HEADER ======= -->
<header id="mainHeader">
    <a href="/" class="logo">
        <svg class="logo-mark" viewBox="0 0 48 48" fill="none">
            <path d="M24 4C25.7818 14.2173 33.7827 22.2182 44 24C33.7827 25.7818 25.7818 33.7827 24 44C22.2182 33.7827 14.2173 25.7818 4 24C14.2173 22.2182 22.2182 14.2173 24 4Z" fill="currentColor" />
        </svg>
        <span class="logo-text">Kizuna</span>
    </a>
    <nav>
        <a href="/Shop">New Arrivals</a>
        <a href="/Shop">Collections</a>
        <a href="@Url.Action("Philosophy", "Home")">Philosophy</a>
        <a href="@Url.Action("About", "Home")">About</a>
    </nav>
    <div class="header-actions">
        <button class="icon-btn">Search</button>
        <a href="/Cart/Index" class="icon-btn" style="text-decoration:none">Bag <span class="cart-count">0</span></a>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <span class="icon-btn">@User.Identity.Name</span>

            @if (User.IsInRole(DA_WEB.Models.SD.Role_Admin))
            {
                <a asp-area="Admin"
                       asp-controller="Dashboard"
                       asp-action="Index"
                       class="icon-btn"
                       style="color: var(--accent-gold)">
                    Admin
                </a>
            }

            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="/"
                  method="post"
                  style="display:inline">
                <button type="submit" class="icon-btn">Logout</button>
            </form>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Login" class="icon-btn">Sign In</a>
            <a asp-area="Identity" asp-page="/Account/Register" class="icon-btn">Register</a>
        }
    </div>
</header>

<!-- ======= HERO ======= -->
<section class="hero">
    <div class="hero-left">
        <div class="hero-bg-img"></div>
        <p class="hero-eyebrow">SS25 Collection</p>
        <h1 class="hero-title">
            Sự Giao Thoa<br />
            Giữa <em>Truyền Thống</em><br />
            Và Hiện Đại
        </h1>
        <p class="hero-subtitle">Khám phá vẻ đẹp tối giản mang đậm hơi thở Nhật Bản qua từng đường kim mũi chỉ.</p>
        <div class="hero-cta-row">
            <a href="/Shop" class="btn-primary">
                Khám Phá Ngay
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
            </a>
            <a href="#" class="btn-ghost">Xem Lookbook</a>
        </div>
    </div>
    <div class="hero-right">
        <div class="hero-right-img"></div>
        <div class="hero-tag">New</div>
    </div>
    <div class="hero-scroll-hint">
        <div class="scroll-line"></div>
        <span>Scroll</span>
    </div>
</section>

<!-- ======= MARQUEE ======= -->
<div class="marquee-wrap">
    <div class="marquee-track">
        <span class="marquee-item">
