@model DA_WEB.Models.Product
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_LayoutKizuna.cshtml";
}

@section Styles {
<style>
    /* Ép hiển thị lại chuột (Vẫn giữ để trị dứt điểm template lỗi) */
    body, * { cursor: auto !important; }
    a, button, input[type="submit"], .thumb, .color-swatch, .size-opt, .qty-btn, .tab-btn, .related-card {
        cursor: pointer !important;
    }

    /* BREADCRUMB */
    .breadcrumb {
        background: white; padding: 14px 48px; border-bottom: 1px solid var(--warm-mid);
        display: flex; align-items: center; gap: 8px;
        font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted);
    }
    .breadcrumb a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--primary); }

    /* DETAIL LAYOUT */
    .detail-layout {
        display: grid;
        grid-template-columns: 1fr 1fr; /* Chia đôi để cột ảnh bên trái có không gian */
        min-height: 80vh; max-width: 1440px; margin: 0 auto;
    }

    /* LEFT — IMAGES (ĐÃ NÂNG CẤP THÀNH BỘ SƯU TẬP DỌC) */
    .detail-images-wrapper {
        display: grid;
        grid-template-columns: 80px 1fr; /* 80px cho ảnh thu nhỏ dọc, phần còn lại cho ảnh chính */
        gap: 16px; padding: 32px;
        position: sticky; top: 72px; height: fit-content;
    }

    /* Ảnh thu nhỏ dọc (Thumb Row) */
    .thumb-row-vertical {
        display: flex; flex-direction: column; gap: 10px;
        position: sticky; top: 32px; height: fit-content;
    }
    .thumb {
        width: 100%; aspect-ratio: 1;
        background-size: cover; background-position: center top;
        opacity: 0.4; transition: opacity 0.3s, border-color 0.3s;
        border: 1px solid transparent; /* Viền mỏng tinh tế */
        cursor: pointer;
    }
    .thumb.active { opacity: 1; border-color: var(--ink); /* Viền đậm khi active */ }
    .thumb:hover { opacity: 0.8; }

    /* KHU VỰC ẢNH CHÍNH — TRƯỢT/KÉO (MAIN SLIDER) */
    .gallery-container {
        width: 100%; aspect-ratio: 4/5;
        overflow: hidden; background: var(--warm-mid);
        position: relative;
    }

    /* Băng chuyền ngang thực thụ */
    .main-image-slider {
        display: flex;
        width: 100%; height: 100%;
        overflow-x: auto; /* Cho phép cuộn ngang */
        scroll-snap-type: x mandatory; /* Kích hoạt Native Snapping để trượt/kéo mượt mà */
        scroll-behavior: smooth; /* Click thumbnail thì trượt mượt */
        -webkit-overflow-scrolling: touch; /* Mượt trên mobile */
    }
    /* Giấu thanh cuộn ngang đi */
    .main-image-slider::-webkit-scrollbar { display: none; }

    /* Mỗi tấm ảnh trong slider */
    .slide {
        flex: 0 0 100%; /* Mỗi tấm chiếm đủ 100% chiều rộng */
        height: 100%;
        scroll-snap-align: start; /* Dừng lại chính xác ở đầu mỗi slide */
        overflow: hidden;
    }
    .slide-img {
        width: 100%; height: 100%;
        background-size: cover; background-position: center top;
        transition: transform 0.8s cubic-bezier(.16,1,.3,1);
    }
    .gallery-container:hover .slide-img { transform: scale(1.02); /* Zoom nhẹ khi hover */ }

    /* RIGHT — INFO (Giữ nguyên phong cách sang trọng) */
    .detail-info { padding: 64px 56px; background: white; border-left: 1px solid var(--warm-mid); }
    .detail-tag { font-size: 9px; letter-spacing: 0.45em; text-transform: uppercase; color: var(--primary); margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
    .detail-tag::before { content: ''; display: block; width: 20px; height: 1px; background: var(--primary); }
    .detail-name { font-family: 'Cormorant Garamond', serif; font-size: clamp(36px, 3vw, 52px); font-weight: 300; color: var(--ink); line-height: 1.1; margin-bottom: 20px; }
    .detail-price-wrap { margin-bottom: 32px; }
    .detail-price { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 300; color: var(--ink); }
    .detail-sale-price { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 300; color: var(--primary); }
    .detail-original-price { font-size: 18px; color: var(--muted); text-decoration: line-through; margin-left: 12px; }
    .detail-divider { height: 1px; background: var(--warm-mid); margin: 28px 0; }
    .detail-desc { font-size: 13px; font-weight: 300; letter-spacing: 0.04em; color: rgba(26,20,16,0.65); line-height: 2; margin-bottom: 32px; }

    /* COLOR swatches */
    .option-label { font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; }
    .color-row { display: flex; gap: 10px; margin-bottom: 28px; }
    .color-swatch { width: 28px; height: 28px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s; }
    .color-swatch.active { border-color: var(--primary); }
    .color-swatch:hover { border-color: var(--muted); }

    /* SIZE options */
    .size-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }
    .size-opt { padding: 10px 18px; border: 1px solid var(--warm-mid); background: none; cursor: pointer; font-family: 'Josefin Sans', sans-serif; font-size: 11px; letter-spacing: 0.1em; color: var(--muted); transition: all 0.2s; }
    .size-opt:hover { border-color: var(--ink); color: var(--ink); }
    .size-opt.active { background: var(--ink); border-color: var(--ink); color: white; }
    .size-guide { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); text-decoration: none; border-bottom: 1px solid var(--warm-mid); padding-bottom: 1px; transition: color 0.2s, border-color 0.2s; display: inline-block; margin-bottom: 28px; }
    .size-guide:hover { color: var(--primary); border-color: var(--primary); }

    /* QTY wrap */
    .qty-wrap { display: flex; align-items: center; gap: 0; border: 1px solid var(--warm-mid); width: fit-content; margin-bottom: 24px; }
    .qty-btn { width: 40px; height: 44px; background: none; border: none; cursor: pointer; font-size: 18px; color: var(--muted); transition: color 0.2s, background 0.2s; display: flex; align-items: center; justify-content: center; }
    .qty-btn:hover { color: var(--primary); background: var(--paper); }
    .qty-input { width: 56px; height: 44px; border: none; border-left: 1px solid var(--warm-mid); border-right: 1px solid var(--warm-mid); text-align: center; font-family: 'Josefin Sans', sans-serif; font-size: 14px; color: var(--ink); outline: none; }

    /* BUTTONS */
    .btn-cart { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 18px; background: var(--primary); color: white; border: none; cursor: pointer; font-family: 'Josefin Sans', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase; transition: background 0.3s, transform 0.2s; clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%); margin-bottom: 12px; }
    .btn-cart:hover { background: var(--primary-dark); transform: translateY(-1px); }
    .btn-cart .material-symbols-outlined { font-size: 18px; }
    .btn-wishlist { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 16px; background: none; color: var(--ink); border: 1px solid var(--warm-mid); cursor: pointer; font-family: 'Josefin Sans', sans-serif; font-size: 10px; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; transition: all 0.2s; }
    .btn-wishlist:hover { border-color: var(--primary); color: var(--primary); }
    .btn-wishlist .material-symbols-outlined { font-size: 16px; }

    /* TRUST badges */
    .trust-row { display: flex; gap: 24px; flex-wrap: wrap; margin-top: 28px; padding-top: 28px; border-top: 1px solid var(--warm-mid); }
    .trust-item { display: flex; align-items: center; gap: 8px; font-size: 10px; letter-spacing: 0.08em; color: var(--muted); }
    .trust-item .material-symbols-outlined { font-size: 16px; color: var(--primary); }

    /* TABS */
    .tabs-section { padding: 64px 48px; background: var(--paper); }
    .tabs-nav { display: flex; gap: 0; border-bottom: 1px solid var(--warm-mid); margin-bottom: 48px; }
    .tab-btn { padding: 16px 32px; background: none; border: none; cursor: pointer; font-family: 'Josefin Sans', sans-serif; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--muted); border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color 0.2s, border-color 0.2s; }
    .tab-btn.active { color: var(--ink); border-bottom-color: var(--primary); }
    .tab-btn:hover { color: var(--ink); }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    .detail-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
    .spec-title { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 300; color: var(--ink); margin-bottom: 20px; }
    .spec-desc { font-size: 13px; font-weight: 300; letter-spacing: 0.04em; color: rgba(26,20,16,0.65); line-height: 2; margin-bottom: 24px; }
    .spec-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .spec-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 12px; font-weight: 300; letter-spacing: 0.04em; color: rgba(26,20,16,0.65); line-height: 1.7; }
    .spec-list li::before { content: ''; display: block; flex-shrink: 0; width: 4px; height: 4px; border-radius: 50%; background: var(--primary); margin-top: 8px; }
    .spec-table { background: white; border: 1px solid var(--warm-mid); }
    .spec-row { display: flex; border-bottom: 1px solid var(--warm-mid); }
    .spec-row:last-child { border-bottom: none; }
    .spec-key { width: 160px; padding: 14px 20px; flex-shrink: 0; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); background: var(--paper); border-right: 1px solid var(--warm-mid); }
    .spec-val { padding: 14px 20px; flex: 1; font-size: 12px; font-weight: 400; color: var(--ink); letter-spacing: 0.04em; }

    /* RELATED product cards */
    .related-section { padding: 64px 48px; background: white; border-top: 1px solid var(--warm-mid); }
    .related-header { margin-bottom: 40px; }
    .related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
    .related-card { cursor: pointer; text-decoration: none; color: inherit; display: block; }
    .related-img { aspect-ratio: 3/4; background-size: cover; background-position: center top; background-color: var(--warm-mid); margin-bottom: 14px; overflow: hidden; transition: transform 0.6s cubic-bezier(.16,1,.3,1); }
    .related-card:hover .related-img { transform: scale(1.04); }
    .related-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 400; color: var(--ink); margin-bottom: 4px; }
    .related-price { font-size: 12px; color: var(--muted); letter-spacing: 0.05em; }

    /* STOCK labels */
    .stock-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #2d7a4f; margin-bottom: 20px; }
    .stock-badge::before { content: ''; display: block; width: 6px; height: 6px; border-radius: 50%; background: #2d7a4f; }
    .stock-badge.low { color: var(--primary); }
    .stock-badge.low::before { background: var(--primary); }
</style>
}

<div class="breadcrumb">
    <a href="/">Home</a>
    <span>›</span>
    <a href="/Shop">Shop</a>
    <span>›</span>
    @if (Model.Category != null)
    {
        <a href="/Shop?categoryId=@Model.CategoryId">@Model.Category.Name</a>
        <span>›</span>
    }
    <span style="color:var(--ink)">@Model.Name</span>
</div>

<div class="detail-layout">

    <div class="detail-images-wrapper">
        
        <div class="thumb-row-vertical">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="thumb active" style="background-image:url('@Model.ImageUrl')"
                     onclick="slideToImage(0, this)"></div>
            }
            
            @if (Model.ProductImages != null && Model.ProductImages.Any())
            {
                var index = 1;
                foreach (var img in Model.ProductImages)
                {
                    <div class="thumb" style="background-image:url('@img.ImageUrl')"
                         onclick="slideToImage(@index, this)"></div>
                    index++;
                }
            }
        </div>

        <div class="gallery-container">
            <div class="main-image-slider" id="mainImageSlider">
                
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="slide">
                        <div class="slide-img" style="background-image:url('@Model.ImageUrl')"></div>
                    </div>
                }

                @if (Model.ProductImages != null && Model.ProductImages.Any())
                {
                    foreach (var img in Model.ProductImages)
                    {
                        <div class="slide">
                            <div class="slide-img" style="background-image:url('@img.ImageUrl')"></div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="detail-info">
        @if (Model.Category != null)
        {
            <div class="detail-tag">@Model.Category.Name</div>
        }
        <h1 class="detail-name">@Model.Name</h1>
        <div class="detail-price-wrap">
            @if (Model.SalePrice.HasValue)
            {
                <span class="detail-sale-price">@Model.SalePrice.Value.ToString("N0")₫</span>
                <span class="detail-original-price">@Model.Price.ToString("N0")₫</span>
            }
            else
            {
                <span class="detail-price">@Model.Price.ToString("N0")₫</span>
            }
        </div>
        @if (Model.Stock > 10) { <div class="stock-badge">In stock — @Model.Stock units available</div> }
        else if (Model.Stock > 0) { <div class="stock-badge low">Low stock — only @Model.Stock left</div> }
        else { <div class="stock-badge low">Out of stock</div> }
        <div class="detail-divider"></div>
        @if (!string.IsNullOrEmpty(Model.Description)) { <p class="detail-desc">@Model.Description</p> }
        <div class="option-label">Color</div>
        <div class="color-row">
            <div class="color-swatch active" style="background:#f7f4f0;border:1px solid var(--warm-mid)" title="Cream"></div>
            <div class="color-swatch" style="background:#2a2520" title="Charcoal"></div>
            <div class="color-swatch" style="background:#5a6b5e" title="Sage"></div>
        </div>
        <div class="option-label">Size</div>
        <div class="size-row">
            <button type="button" class="size-opt" onclick="selectSize(this, 'S')">S</button>
            <button type="button" class="size-opt" onclick="selectSize(this, 'M')">M</button>
            <button type="button" class="size-opt" onclick="selectSize(this, 'L')">L</button>
            <button type="button" class="size-opt" onclick="selectSize(this, 'XL')">XL</button>
        </div>
        <a href="#" class="size-guide">Size Guide</a>
        <div class="option-label">Quantity</div>
        <div class="qty-wrap">
            <button class="qty-btn" onclick="changeQty(-1)">−</button>
            <input type="number" class="qty-input" id="qtyInput" value="1" min="1" max="@Model.Stock" />
            <button class="qty-btn" onclick="changeQty(1)">+</button>
        </div>
        @if (Model.Stock > 0)
        {
           <form asp-controller="Cart" asp-action="Add" method="post" style="width:100%;" onsubmit="return validateSize()">
    <input type="hidden" name="productId" value="@Model.Id" />
    <input type="hidden" name="quantity" id="finalQty" value="1" />
    <input type="hidden" name="size" id="selectedSize" value="" /> <button type="submit" class="btn-cart">
        <span class="material-symbols-outlined">shopping_cart</span> Add to Cart
    </button>
</form>
        }
        else { <button class="btn-cart" disabled style="background:var(--muted);cursor:not-allowed">Out of Stock</button> }
        <button class="btn-wishlist"> <span class="material-symbols-outlined">favorite_border</span> Add to Wishlist </button>
        <div class="trust-row">
            <div class="trust-item"> <span class="material-symbols-outlined">eco</span> Organic materials </div>
            <div class="trust-item"> <span class="material-symbols-outlined">local_shipping</span> Free shipping </div>
            <div class="trust-item"> <span class="material-symbols-outlined">swap_horiz</span> 30-day returns </div>
        </div>
    </div>
</div>

<div class="tabs-section">
    <div class="tabs-nav">
        <button class="tab-btn active" onclick="switchTab('details', this)">Product Details</button>
        <button class="tab-btn" onclick="switchTab('sizing', this)">Size Guide</button>
        <button class="tab-btn" onclick="switchTab('reviews', this)">
    Reviews (@((ViewBag.Reviews as List<DA_WEB.Models.ProductReview>)?.Count ?? 0))
</button>
    </div>
    <div id="tab-details" class="tab-content active">
        <div class="detail-grid-2">
            <div>
                <h2 class="spec-title">Crafted with intention</h2>
                <p class="spec-desc">Each piece from Kizuna is made with the wabi-sabi philosophy.</p>
                <ul class="spec-list">
                    <li>Traditional Japanese-inspired design</li>
                    <li>Natural fabric</li>
                    <li>Hand-finished seams</li>
                </ul>
            </div>
            <div>
                <div class="spec-table">
    <div class="spec-row"> 
        <div class="spec-key">Material</div> 
        <div class="spec-val">@(Model.Material ?? "Natural Fabric")</div> 
    </div>

    <div class="spec-row"> 
        <div class="spec-key">Care</div> 
        <div class="spec-val">@(Model.CareInstructions ?? "Hand wash recommended")</div> 
    </div>

    <div class="spec-row"> 
        <div class="spec-key">SKU</div> 
        <div class="spec-val">@(string.IsNullOrEmpty(Model.SKU) ? $"KZ-{Model.Id.ToString("D4")}" : Model.SKU)</div> 
    </div>
</div>
            </div>
        </div>
    </div>
    <div id="tab-sizing" class="tab-content">
        <p style="font-size:13px;color:var(--muted);">Oversized Japanese fit.</p>
    </div>
    <div id="tab-reviews" class="tab-content">
    <div class="review-section">
        
        <div class="review-summary-box">
            <div class="review-score">
                <h2 class="score-number">4.8</h2> <div class="score-stars">
                    <span class="material-symbols-outlined filled">star</span>
                    <span class="material-symbols-outlined filled">star</span>
                    <span class="material-symbols-outlined filled">star</span>
                    <span class="material-symbols-outlined filled">star</span>
                    <span class="material-symbols-outlined half">star_half</span>
                </div>
                <p class="score-count">Dựa trên @((ViewBag.Reviews as List<DA_WEB.Models.ProductReview>)?.Count ?? 0) đánh giá</p>
            </div>

            <div class="review-action-area">
                <p style="font-size: 13px; color: var(--muted); margin-bottom: 12px; line-height: 1.5;">
                    Bạn đã trải nghiệm sản phẩm này? Hãy chia sẻ cảm nhận để giúp những khách hàng khác nhé.
                </p>
                @if (ViewBag.CanReview == true) {
                    <button type="button" class="btn-primary" onclick="openReviewModal()">Viết Đánh Giá</button>
                } else if (!User.Identity.IsAuthenticated) {
                    <a href="/Identity/Account/Login" class="btn-ghost" style="text-decoration: none; display: inline-block;">Đăng nhập để đánh giá</a>
                } else {
                    <div style="padding: 8px 16px; background: var(--paper); font-size: 12px; color: var(--muted); border-radius: 4px;">
                        Chỉ khách hàng đã nhận sản phẩm mới có thể đánh giá.
                    </div>
                }
            </div>
        </div>

        <div class="reviews-list">
            @{ var reviews = ViewBag.Reviews as List<DA_WEB.Models.ProductReview>; }
            @if (reviews != null && reviews.Any()) {
                @foreach (var r in reviews) {
                    <div class="review-item">
                        <div class="review-header">
                            <div class="review-user-info">
                                <div class="user-avatar">@(r.User?.FullName?.Substring(0, 1).ToUpper() ?? "K")</div>
                                <div>
                                    <strong class="user-name">@r.User?.FullName</strong>
                                    <span class="verified-badge"><span class="material-symbols-outlined" style="font-size: 12px;">verified</span> Đã mua hàng</span>
                                </div>
                            </div>
                            <span class="review-date">@r.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="review-stars-display">
                            @for(int i=1; i<=5; i++) {
                                <span class="material-symbols-outlined @(i <= r.Rating ? "filled" : "")">star</span>
                            }
                        </div>
                        <p class="review-comment">@r.Comment</p>
                    </div>
                }
            } else {
                <div style="text-align: center; padding: 60px 0;">
                    <span class="material-symbols-outlined" style="font-size: 48px; color: var(--paper);">rate_review</span>
                    <p style="color: var(--muted); font-size: 14px; margin-top: 16px;">Sản phẩm chưa có đánh giá nào.<br/>Hãy là người đầu tiên trải nghiệm và chia sẻ!</p>
                </div>
            }
        </div>
    </div>
</div>

<div id="reviewModal" class="kizuna-modal">
    <div class="kizuna-modal-content">
        <span class="close-modal" onclick="closeReviewModal()">&times;</span>
        <h3 class="modal-title">Đánh giá sản phẩm</h3>
        <p class="modal-subtitle">@Model.Name</p>
        
        <form asp-action="PostReview" method="post">
            <input type="hidden" name="productId" value="@Model.Id" />
            
            <div class="rating-input-group">
                <label>Chất lượng sản phẩm</label>
                <div class="star-rating-select">
                    <input type="radio" id="star5" name="rating" value="5" required /><label for="star5" title="5 sao"></label>
                    <input type="radio" id="star4" name="rating" value="4" /><label for="star4" title="4 sao"></label>
                    <input type="radio" id="star3" name="rating" value="3" /><label for="star3" title="3 sao"></label>
                    <input type="radio" id="star2" name="rating" value="2" /><label for="star2" title="2 sao"></label>
                    <input type="radio" id="star1" name="rating" value="1" /><label for="star1" title="1 sao"></label>
                </div>
            </div>

            <div class="form-group">
                <label>Chia sẻ trải nghiệm của bạn</label>
                <textarea name="comment" class="field-input" placeholder="Phom dáng có vừa vặn không? Chất liệu vải thế nào?..." required rows="4"></textarea>
            </div>
            
            <button type="submit" class="btn-primary" style="width: 100%; margin-top: 16px;">Gửi Đánh Giá</button>
        </form>
    </div>
</div>
</div>
</div>

@if (ViewBag.RelatedProducts != null)
{
    var related = (IEnumerable<DA_WEB.Models.Product>)ViewBag.RelatedProducts;
    if (related.Any())
    {
        <div class="related-section">
            <div class="related-header">
                <div style="font-size:9px;letter-spacing:0.45em;text-transform:uppercase;color:var(--primary);margin-bottom:10px;display:flex;align-items:center;gap:10px"> <span style="display:block;width:20px;height:1px;background:var(--primary)"></span> You may also like </div>
                <h2 style="font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:300;color:var(--ink)">Related Products</h2>
            </div>
            <div class="related-grid">
                @foreach (var p in related.Take(4))
                {
                    <a href="/Shop/Detail/@p.Id" class="related-card">
                        <div class="related-img" style="background-image:url('@(p.ImageUrl ?? "")')"></div>
                        <div class="related-name">@p.Name</div>
                        <div class="related-price">@p.Price.ToString("N0")₫</div>
                    </a>
                }
            </div>
        </div>
    }
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

@section Scripts {
    <style>
        /* KHỐI THỐNG KÊ */
        .review-section { max-width: 800px; margin: 0 auto; padding: 40px 0; }
        .review-summary-box { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; background: #faf9f7; padding: 40px; border-radius: 8px; margin-bottom: 48px; }
        .review-score { text-align: center; border-right: 1px solid var(--warm-mid); }
        .score-number { font-family: 'Cormorant Garamond', serif; font-size: 56px; line-height: 1; color: var(--ink); margin-bottom: 8px; font-weight: 300; }
        .score-stars .material-symbols-outlined { color: #e0e0e0; font-size: 20px; }
        .score-stars .filled, .score-stars .half { color: var(--accent-gold, #cfa872); }
        .score-count { font-size: 12px; color: var(--muted); margin-top: 8px; text-transform: uppercase; letter-spacing: 0.05em; }
        .review-action-area { display: flex; flex-direction: column; justify-content: center; }

        /* DANH SÁCH ITEM */
        .review-item { border-bottom: 1px solid var(--paper); padding: 32px 0; }
        .review-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .review-user-info { display: flex; align-items: center; gap: 12px; }
        .user-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--warm-mid); color: var(--ink); display: flex; align-items: center; justify-content: center; font-weight: bold; font-family: 'Cormorant Garamond', serif; font-size: 18px; }
        .user-name { font-size: 14px; color: var(--ink); display: block; }
        .verified-badge { font-size: 11px; color: #3b82f6; display: flex; align-items: center; gap: 4px; margin-top: 2px; }
        .review-date { font-size: 12px; color: var(--muted); }
        .review-stars-display .material-symbols-outlined { font-size: 14px; color: #e0e0e0; }
        .review-stars-display .filled { color: var(--accent-gold, #cfa872); }
        .review-comment { font-size: 14px; line-height: 1.6; color: var(--ink); margin-top: 12px; }

        /* MODAL POPUP */
        .kizuna-modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5); backdrop-filter: blur(4px); }
        .kizuna-modal-content { background-color: #fff; margin: 10% auto; padding: 40px; border-radius: 8px; width: 90%; max-width: 500px; position: relative; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
        .close-modal { position: absolute; right: 24px; top: 24px; color: var(--muted); font-size: 28px; font-weight: 300; cursor: pointer; line-height: 1; }
        .close-modal:hover { color: var(--ink); }
        .modal-title { font-family: 'Cormorant Garamond', serif; font-size: 28px; color: var(--ink); margin-bottom: 4px; }
        .modal-subtitle { font-size: 13px; color: var(--muted); margin-bottom: 32px; padding-bottom: 16px; border-bottom: 1px solid var(--paper); }
        
        /* HIỆU ỨNG CHỌN SAO NGHỆ THUẬT */
        .rating-input-group { margin-bottom: 24px; text-align: center; }
        .rating-input-group label { display: block; font-size: 11px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; letter-spacing: 0.1em; }
        .star-rating-select { display: inline-flex; flex-direction: row-reverse; gap: 8px; }
        .star-rating-select input { display: none; }
        .star-rating-select label { cursor: pointer; color: #e0e0e0; font-size: 32px; transition: color 0.2s; }
        .star-rating-select label:before { content: '★'; }
        .star-rating-select input:checked ~ label { color: var(--accent-gold, #cfa872); }
        .star-rating-select label:hover, .star-rating-select label:hover ~ label { color: var(--accent-gold, #cfa872); opacity: 0.7; }
        .form-group label { display: block; font-size: 11px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; letter-spacing: 0.1em; }
    </style>

    <script>
        // --- CODE MỚI: XỬ LÝ MODAL ĐÁNH GIÁ ---
        var modal = document.getElementById("reviewModal");
        
        function openReviewModal() { 
            if(modal) modal.style.display = "block"; 
        }
        
        function closeReviewModal() { 
            if(modal) modal.style.display = "none"; 
        }
        
        window.onclick = function(event) {
            if (event.target == modal) { 
                closeReviewModal(); 
            }
        }

        // --- CODE CŨ: GIỮ NGUYÊN HOÀN TOÀN CỦA TIẾN ---
        const slider = document.getElementById('mainImageSlider');
        const thumbs = document.querySelectorAll('.thumb');
        
        function slideToImage(index, thumb) {
            if(!slider) return; // Tránh lỗi nếu không có slider
            const slideWidth = slider.querySelector('.slide').offsetWidth;
            slider.scrollTo({
                left: index * slideWidth,
                behavior: 'smooth' 
            });
            updateActiveThumb(thumb);
        }
        
        if(slider) {
            slider.addEventListener('scroll', function() {
                const slideWidth = slider.querySelector('.slide').offsetWidth;
                const currentIndex = Math.floor((slider.scrollLeft + slideWidth / 2) / slideWidth);
                updateActiveThumb(thumbs[currentIndex]);
            });
        }
        
        function updateActiveThumb(activeThumb) {
            if (!activeThumb) return;
            thumbs.forEach(t => t.classList.remove('active'));
            activeThumb.classList.add('active');
        }

        function changeQty(delta) {
            const input = document.getElementById('qtyInput');
            if(!input) return;
            const max = parseInt(input.max) || 999;
            let val = parseInt(input.value) + delta;
            if (val < 1) val = 1;
            if (val > max) val = max;
            input.value = val;
            document.getElementById('finalQty').value = val;
        }

        const qtyInput = document.getElementById('qtyInput');
        if(qtyInput) {
            qtyInput.addEventListener('input', function() {
                document.getElementById('finalQty').value = this.valueAsNumber || 1;
            });
        }

        function switchTab(name, btn) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            btn.classList.add('active');
        }

        document.querySelectorAll('.color-swatch').forEach(sw => {
            sw.addEventListener('click', function () {
                document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
                this.classList.add('active');
            });
        });

        function selectSize(btn, sizeValue) {
            document.querySelectorAll('.size-opt').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('selectedSize').value = sizeValue;
        }

        function validateSize() {
            var size = document.getElementById('selectedSize').value;
            if (!size) {
                alert("Vui lòng chọn Size trước khi thêm vào giỏ hàng!");
                return false; 
            }
            return true;
        }
    </script>
}