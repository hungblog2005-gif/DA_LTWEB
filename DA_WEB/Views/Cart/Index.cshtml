@model Cart
@{
    ViewData["Title"] = "Giỏ hàng - Phong cách tối giản Nhật Bản";
    Layout = "_LayoutTailwind";
}
<main class="flex-1 max-w-7xl mx-auto w-full px-6 md:px-20 py-12">
    <div class="mb-10">
        <h2 class="text-3xl font-light text-slate-900 tracking-tight">Giỏ hàng của bạn</h2>
        <p class="text-slate-500 mt-2 font-light">Hiện đang có @(Model?.Items.Count ?? 0) sản phẩm trong danh sách</p>
    </div>
    @if (Model?.Items.Count > 0)
    {
        <div class="flex flex-col lg:flex-row gap-16">
            <!-- Products List -->
            <div class="flex-[2] space-y-8">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="border-b border-slate-200">
                            <tr>
                                <th class="pb-4 font-medium text-sm text-slate-400 uppercase tracking-wider">Sản phẩm</th>
                                <th class="pb-4 font-medium text-sm text-slate-400 uppercase tracking-wider text-center">Số lượng</th>
                                <th class="pb-4 font-medium text-sm text-slate-400 uppercase tracking-wider text-right">Thành tiền</th>
                                <th class="pb-4"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @foreach (var item in Model.Items)
                            {
                                <tr class="group">
                                    <td class="py-8">
                                        <div class="flex items-center gap-6">
                                            <div class="size-24 bg-slate-100 rounded-lg overflow-hidden flex-shrink-0">
                                                @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                                {
                                                    <img class="w-full h-full object-cover" src="@item.Product.ImageUrl" alt="@item.Product.Name" />
                                                }
                                                else
                                                {
                                                    <div class="w-full h-full flex items-center justify-center text-gray-400 dark:text-slate-500">[Ảnh]</div>
                                                }
                                            </div>
                                            <div>
                                                <h3 class="text-lg font-normal text-slate-900">@item.Product.Name</h3>
                                                <p class="text-slate-500 text-sm mt-1">@item.Product.Description</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-8">
                                        <div class="flex items-center justify-center">
                                            <form method="post" asp-action="Update" asp-controller="Cart" style="display:inline;">
                                                <div class="flex items-center border border-slate-200 rounded-lg bg-white">
                                                    <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="px-3 py-1 text-slate-400 hover:text-primary">-</button>
                                                    <span class="px-2 py-1 text-sm font-medium w-8 text-center">@item.Quantity</span>
                                                    <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="px-3 py-1 text-slate-400 hover:text-primary">+</button>
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                </div>
                                            </form>
                                        </div>
                                    </td>
                                    <td class="py-8 text-right font-medium text-slate-900">
                                        @((item.Quantity * item.UnitPrice).ToString("N0"))₫
                                    </td>
                                    <td class="py-8 text-right">
                                        <form method="post" asp-action="Remove" asp-controller="Cart" style="display:inline;">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="text-slate-300 hover:text-primary transition-colors">
                                                <span class="material-symbols-outlined">delete</span>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="pt-6">
                    <a class="inline-flex items-center text-sm text-slate-600 hover:text-primary transition-colors gap-2" href="/Shop">
                        <span class="material-symbols-outlined text-base">arrow_back</span>
                        Tiếp tục mua sắm
                    </a>
                </div>
            </div>
            <!-- Order Summary Side Bar -->
            <div class="flex-1">
                <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-100 sticky top-32">
                    <h3 class="text-xl font-medium text-slate-900 mb-8 border-b border-slate-50 pb-4">Tóm tắt đơn hàng</h3>
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between items-center">
                            <span class="text-slate-500 font-light">Tạm tính</span>
                            <span class="text-slate-900 font-medium">@Model.Items.Sum(i => i.Quantity * i.UnitPrice).ToString("N0")₫</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-500 font-light">Phí vận chuyển</span>
                            <span class="text-primary font-medium">Miễn phí</span>
                        </div>
                        <div class="pt-4 border-t border-slate-50 flex justify-between items-center">
                            <span class="text-lg font-medium text-slate-900">Tổng cộng</span>
                            <div class="text-right">
                                <span class="text-2xl font-bold text-slate-900">@Model.Items.Sum(i => i.Quantity * i.UnitPrice).ToString("N0")₫</span>
                                <p class="text-xs text-slate-400 mt-1">(Đã bao gồm VAT nếu có)</p>
                            </div>
                        </div>
                    </div>
                    <a href="/Order/Checkout" class="w-full bg-primary text-white py-4 rounded-lg font-medium tracking-wide hover:bg-primary/90 transition-all flex items-center justify-center gap-2">
                        Thanh toán ngay
                        <span class="material-symbols-outlined text-lg">arrow_forward</span>
                    </a>
                    <div class="mt-8 space-y-4">
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-slate-400 text-lg">local_shipping</span>
                            <p class="text-xs text-slate-500">Giao hàng dự kiến: 2 - 4 ngày làm việc</p>
                        </div>
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-slate-400 text-lg">verified_user</span>
                            <p class="text-xs text-slate-500">Thanh toán bảo mật và an toàn qua thẻ tín dụng hoặc chuyển khoản</p>
                        </div>
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-slate-400 text-lg">replay</span>
                            <p class="text-xs text-slate-500">Chính sách đổi trả trong vòng 30 ngày cho tất cả sản phẩm</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-12">
            <p class="text-lg text-gray-500 dark:text-slate-400">Giỏ hàng của bạn đang trống.</p>
            <a href="/Shop" class="mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-primary hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                Tiếp tục mua sắm
            </a>
        </div>
    }
</main>