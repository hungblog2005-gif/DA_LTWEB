@model DA_WEB.Models.Cart
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Views/Shared/_LayoutKizuna.cshtml";
    
    // Lấy tổng tiền từ ViewBag (Controller truyền sang)
    var totalPrice = ViewBag.TotalPrice != null ? (decimal)ViewBag.TotalPrice : 0;
}

@section Styles {
<style>
    .breadcrumb {
        background: white; padding: 14px 48px; border-bottom: 1px solid var(--warm-mid);
        display: flex; align-items: center; gap: 8px;
        font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted);
    }
    .breadcrumb a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--primary); }

    .cart-container {
        max-width: 1440px; margin: 0 auto; padding: 64px 48px;
        min-height: 70vh;
    }
    .page-title {
        font-family: 'Cormorant Garamond', serif; font-size: 48px; font-weight: 300; 
        color: var(--ink); margin-bottom: 48px;
    }

    /* Layout chia 2 cột: Danh sách SP và Tóm tắt đơn hàng */
    .cart-layout {
        display: grid; grid-template-columns: 7fr 3.5fr; gap: 64px;
    }

    /* BẢNG GIỎ HÀNG */
    .cart-table { width: 100%; border-collapse: collapse; }
    .cart-table th {
        text-align: left; padding-bottom: 16px; border-bottom: 1px solid var(--warm-mid);
        font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted);
        font-weight: 400;
    }
    .cart-table td {
        padding: 32px 0; border-bottom: 1px solid var(--warm-mid); vertical-align: middle;
    }
    
    .item-info { display: flex; gap: 24px; align-items: center; }
    .item-img {
        width: 100px; aspect-ratio: 3/4; background-size: cover; background-position: center top;
        background-color: var(--warm-mid); border: 1px solid var(--warm-mid);
    }
    .item-details { display: flex; flex-direction: column; gap: 8px; }
    .item-name {
        font-family: 'Cormorant Garamond', serif; font-size: 22px; color: var(--ink);
        text-decoration: none; transition: color 0.2s;
    }
    .item-name:hover { color: var(--primary); }
    .item-price { font-size: 14px; color: var(--muted); }
    
    .btn-remove {
        background: none; border: none; color: #d9534f; cursor: pointer;
        font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
        display: flex; align-items: center; gap: 4px; padding: 0; margin-top: 8px;
        transition: opacity 0.2s;
    }
    .btn-remove:hover { opacity: 0.7; }

    /* BỘ CHỈNH SỐ LƯỢNG */
    .qty-form { display: flex; align-items: center; border: 1px solid var(--warm-mid); width: fit-content; }
    .qty-btn {
        width: 32px; height: 36px; background: none; border: none; cursor: pointer;
        font-size: 16px; color: var(--muted); display: flex; align-items: center; justify-content: center;
    }
    .qty-btn:hover { color: var(--ink); background: var(--paper); }
    .qty-input {
        width: 40px; height: 36px; border: none; border-left: 1px solid var(--warm-mid); border-right: 1px solid var(--warm-mid);
        text-align: center; font-family: 'Josefin Sans', sans-serif; font-size: 13px; color: var(--ink); outline: none;
        -moz-appearance: textfield;
    }
    .qty-input::-webkit-outer-spin-button, .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

    .item-total { font-size: 16px; color: var(--ink); font-weight: 500; text-align: right; }

    /* KHUNG TÓM TẮT ĐƠN HÀNG (SUMMARY) */
    .summary-card {
        background: var(--paper); padding: 40px; height: fit-content; position: sticky; top: 120px;
    }
    .summary-title {
        font-family: 'Cormorant Garamond', serif; font-size: 24px; color: var(--ink);
        margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--warm-mid);
    }
    .summary-row {
        display: flex; justify-content: space-between; margin-bottom: 16px;
        font-size: 13px; color: var(--muted); letter-spacing: 0.05em;
    }
    .summary-total {
        display: flex; justify-content: space-between; margin-top: 24px; padding-top: 24px;
        border-top: 1px solid var(--warm-mid);
        font-family: 'Cormorant Garamond', serif; font-size: 28px; color: var(--ink); font-weight: 300;
    }
    .btn-checkout {
        display: flex; align-items: center; justify-content: center; gap: 10px;
        width: 100%; padding: 18px; margin-top: 32px;
        background: var(--ink); color: white; border: none; cursor: pointer;
        font-family: 'Josefin Sans', sans-serif; font-size: 10px; font-weight: 600;
        letter-spacing: 0.3em; text-transform: uppercase; transition: background 0.3s;
    }
    .btn-checkout:hover { background: var(--primary); }

    /* TRẠNG THÁI GIỎ HÀNG TRỐNG */
    .empty-cart {
        text-align: center; padding: 80px 0;
    }
    .empty-cart .material-symbols-outlined {
        font-size: 64px; color: var(--warm-mid); margin-bottom: 24px;
    }
    .empty-cart h2 {
        font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 300; color: var(--ink); margin-bottom: 16px;
    }
    .empty-cart p {
        font-size: 14px; color: var(--muted); margin-bottom: 32px; letter-spacing: 0.05em;
    }
    .btn-continue {
        display: inline-flex; align-items: center; gap: 8px; padding: 16px 32px;
        border: 1px solid var(--ink); color: var(--ink); text-decoration: none;
        font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; transition: all 0.2s;
    }
    .btn-continue:hover { background: var(--ink); color: white; }
</style>
}

<div class="breadcrumb">
    <a href="/">Home</a> <span>›</span> <span style="color:var(--ink)">Shopping Cart</span>
</div>

<div class="cart-container">
    <h1 class="page-title">Your <em>Cart</em></h1>

    @if (Model == null || Model.Items == null || !Model.Items.Any())
    {
        <div class="empty-cart">
            <span class="material-symbols-outlined">shopping_bag</span>
            <h2>Your cart is currently empty.</h2>
            <p>Discover our latest collection and find something beautiful.</p>
            <a href="/Shop" class="btn-continue">Continue Shopping</a>
        </div>
    }
    else
    {
        <div class="cart-layout">
            <div class="cart-items">
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th style="text-align: center;">Quantity</th>
                            <th style="text-align: right;">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            var currentPrice = item.Product.SalePrice ?? item.Product.Price;
                            var itemTotal = currentPrice * item.Quantity;

                            <tr>
                                <td>
                                    <div class="item-info">
                                        <div class="item-img" style="background-image:url('@(item.Product.ImageUrl ?? "")')"></div>
                                        <div class="item-details">
                                            <a href="/Shop/Detail/@item.ProductId" class="item-name">@item.Product.Name</a>
                                            <span class="item-price">@currentPrice.ToString("N0")₫</span>
                                            
                                            <form asp-controller="Cart" asp-action="Remove" method="post">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn-remove">
                                                    <span class="material-symbols-outlined" style="font-size:14px">close</span> Remove
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <form asp-controller="Cart" asp-action="Update" method="post" style="display:flex; justify-content:center;">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <div class="qty-form">
                                            <button type="button" class="qty-btn" onclick="updateQty(this, -1)">−</button>
                                            <input type="number" name="quantity" class="qty-input" value="@item.Quantity" min="1" onchange="this.form.submit()" />
                                            <button type="button" class="qty-btn" onclick="updateQty(this, 1)">+</button>
                                        </div>
                                    </form>
                                </td>
                                <td class="item-total">
                                    @itemTotal.ToString("N0")₫
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div>
                <div class="summary-card">
                    <h3 class="summary-title">Order Summary</h3>
                    
                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span style="color:var(--ink)">@totalPrice.ToString("N0")₫</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span>Calculated at checkout</span>
                    </div>

                    <div class="summary-total">
                        <span>Total</span>
                        <span>@totalPrice.ToString("N0")₫</span>
                    </div>

                    <a href="/Order/Checkout" class="btn-checkout" style="text-decoration:none">
    Proceed to Checkout <span class="material-symbols-outlined">arrow_forward</span>
</a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    function updateQty(btn, delta) {
        const form = btn.closest('form');
        const input = form.querySelector('.qty-input');
        let currentVal = parseInt(input.value) || 1;
        
        let newVal = currentVal + delta;
        if (newVal < 1) newVal = 1; 
        
        input.value = newVal;
        form.submit();
    }
</script>
}